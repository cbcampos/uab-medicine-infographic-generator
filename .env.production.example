# UAB Medicine Infographic Generator production settings
# Copy to /mnt/data/dockerapps/uab-infographic-generator/.env on the server.
# Do not commit the real .env file.

UAB_INFOGRAPHIC_PRODUCTION=true

# Azure OpenAI only. Do not set OPENAI_API_KEY or GEMINI_API_KEY in production.
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_IMAGE_MODEL=gpt-image-2
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# The production compose file also sets this to the bundled repo asset.
UAB_MEDICINE_LOGO_PATH=/app/assets/uab-medicine-logo.jpg
