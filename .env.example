# UAB Medicine Infographic Generator — Environment Variables
# Copy this to .env and fill in your credentials

# ── OpenAI (GPT Image 2) ────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_VISION_MODEL=gpt-4o

# ── Azure OpenAI (GPT Image 2) ────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_IMAGE_MODEL=gpt-image-2
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# ── Google Gemini (image + chat + vision via app “Gemini” provider) ───────────
GEMINI_API_KEY=your-ai-studio-api-key
GEMINI_CHAT_MODEL=gemini-2.5-pro
GEMINI_VISION_MODEL=gemini-2.5-pro
# Image-gen model IDs — use API resource names, e.g. gemini-3-pro-image-preview (Nano Banana Pro)
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ── Approved UAB Medicine logo (optional; composites exact asset onto output) ──
UAB_MEDICINE_LOGO_PATH=/absolute/path/to/uab-medicine-logo.jpg

# ── Optional: Streamlit secrets (alternative to env vars) ──────
# Create ~/.streamlit/secrets.toml with:
# OPENAI_API_KEY = "sk-..."
# AZURE_OPENAI_API_KEY = "..."
# AZURE_OPENAI_ENDPOINT = "https://..."